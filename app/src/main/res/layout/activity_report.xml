<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#D1CFFF"
    android:padding="16dp">

    <!-- HEADER -->
    <RelativeLayout
        android:id="@+id/reportHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBackReport"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_revert"
            android:tint="#5E17EB"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/txtReportTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/btnBackReport"
            android:layout_centerVertical="true"
            android:layout_marginStart="12dp"
            android:text="Báo Cáo Chi Tiêu"
            android:textColor="#5E17EB"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/btnSelectMonth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@android:color/white"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:text="Tháng 06/2026 ▾"
            android:textColor="#5E17EB"
            android:textStyle="bold"
            android:textSize="14sp"/>
    </RelativeLayout>

    <!-- SUMMARY -->
    <LinearLayout
        android:id="@+id/layoutReportSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@android:color/white"
        android:orientation="horizontal"
        android:padding="12dp"
        android:weightSum="2"
        android:elevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/reportHeader">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tổng thu"
                android:textColor="#777777"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/txtReportIncome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+0đ"
                android:textColor="#2E7D32"
                android:textSize="15sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#E0E0E0"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tổng chi"
                android:textColor="#777777"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/txtReportExpense"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-0đ"
                android:textColor="#C62828"
                android:textSize="15sp"
                android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>

    <!-- TREND CARD -->
    <TextView
        android:id="@+id/txtTrend"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@android:color/white"
        android:padding="12dp"
        android:text="Xu hướng: Ổn định"
        android:textColor="#444444"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/layoutReportSummary"/>

    <Button
        android:id="@+id/btnFilterDate"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Lọc theo ngày"
        android:backgroundTint="#3949AB"
        android:textColor="#fff"
        app:layout_constraintBottom_toTopOf="@id/btnExport"/>

    <!-- REPORT LIST -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardReportList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/txtTrend"
        app:layout_constraintBottom_toTopOf="@id/btnExport">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCategoryReport"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp"/>
    </androidx.cardview.widget.CardView>

    <!-- EXPORT -->
    <Button
        android:id="@+id/btnExport"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="12dp"
        android:backgroundTint="#5E17EB"
        android:text="Xuất báo cáo"
        android:textColor="#FFFFFF"
        app:layout_constraintBottom_toTopOf="@id/btnViewHistory"/>

    <!-- HISTORY -->
    <Button
        android:id="@+id/btnViewHistory"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="10dp"
        android:backgroundTint="#7B1FA2"
        android:text="Xem báo cáo đã xuất"
        android:textColor="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>