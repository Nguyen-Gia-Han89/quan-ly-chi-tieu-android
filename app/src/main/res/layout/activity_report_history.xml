<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#D1CFFF"
    android:padding="16dp">

    <!-- HEADER -->
    <RelativeLayout
        android:id="@+id/reportHistoryHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- BACK -->
        <ImageView
            android:id="@+id/btnBackReportHistory"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_revert"
            android:tint="#5E17EB"
            android:clickable="true"
            android:focusable="true"/>

        <!-- TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/btnBackReportHistory"
            android:layout_centerVertical="true"
            android:layout_marginStart="12dp"
            android:text="DANH SÁCH BÁO CÁO"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#5E17EB"/>
    </RelativeLayout>

    <!-- LIST FILE REPORT -->
    <ListView
        android:id="@+id/listViewReports"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:divider="#CCCCCC"
        android:dividerHeight="1dp"
        app:layout_constraintTop_toBottomOf="@id/reportHistoryHeader"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>