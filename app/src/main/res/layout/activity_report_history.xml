<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#D1CFFF"
    android:padding="0dp">

    <!--HEADER-->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/reportHistoryHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- BACK -->
        <ImageView
            android:id="@+id/btnBackReportHistory"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_menu_revert"
            android:tint="#5E17EB"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <!-- TITLE -->
        <TextView
            android:id="@+id/txtReportHistoryTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Danh Sách Báo Cáo"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#5E17EB"
            android:layout_marginStart="10dp"
            app:layout_constraintStart_toEndOf="@id/btnBackReportHistory"
            app:layout_constraintEnd_toStartOf="@id/btnSort"
            app:layout_constraintTop_toTopOf="@id/btnBackReportHistory"/>

        <!-- SORT -->
        <ImageButton
            android:id="@+id/btnSort"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_filter"
            android:tint="#5E17EB"
            android:contentDescription="Sắp xếp"
            app:layout_constraintEnd_toStartOf="@id/btnSelectMonth"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginEnd="6dp"/>

        <!-- MONTH -->
        <TextView
            android:id="@+id/btnSelectMonth"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:paddingHorizontal="10dp"
            android:gravity="center"
            android:text="Tháng 06/2026 ▾"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#5E17EB"
            android:background="@android:color/white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <!-- DELETE -->
        <Button
            android:id="@+id/btnDelete"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Xoá"
            android:textSize="12sp"
            android:backgroundTint="#D32F2F"
            android:textColor="#FFFFFF"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@id/btnSelectMonth"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- SUMMARY -->
    <LinearLayout
        android:id="@+id/layoutReportSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@android:color/white"
        android:orientation="horizontal"
        android:padding="12dp"
        android:weightSum="2"
        android:elevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/reportHistoryHeader">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tổng báo cáo"
                android:textSize="12sp"
                android:textColor="#777777"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtTotalReports"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#5E17EB"/>
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#E0E0E0"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gần nhất"
                android:textSize="12sp"
                android:textColor="#777777"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtLatestReport"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chưa có"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#2E7D32"/>
        </LinearLayout>

    </LinearLayout>

    <!-- LIST -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardReportList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/layoutReportSummary"
        app:layout_constraintBottom_toBottomOf="parent">

        <ListView
            android:id="@+id/listViewReports"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="#EEEEEE"
            android:dividerHeight="1dp"
            android:padding="8dp"/>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>