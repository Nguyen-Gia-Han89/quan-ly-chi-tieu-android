<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#D1CFFF"
    android:padding="16dp">

    <!-- HEADER -->
    <RelativeLayout
        android:id="@+id/reportHistoryHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBackReportHistory"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_revert"
            android:tint="#5E17EB"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/txtReportHistoryTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/btnBackReportHistory"
            android:layout_centerVertical="true"
            android:layout_marginStart="12dp"
            android:text="Danh Sách Báo Cáo"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#5E17EB"/>
    </RelativeLayout>

    <!-- SUMMARY -->
    <LinearLayout
        android:id="@+id/layoutReportSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@android:color/white"
        android:orientation="horizontal"
        android:padding="12dp"
        android:weightSum="2"
        android:elevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/reportHistoryHeader">

        <!-- TOTAL REPORTS -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tổng báo cáo"
                android:textSize="12sp"
                android:textColor="#777777"/>

            <TextView
                android:id="@+id/txtTotalReports"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#5E17EB"/>
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#E0E0E0"/>

        <!-- LAST REPORT -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gần nhất"
                android:textSize="12sp"
                android:textColor="#777777"/>

            <TextView
                android:id="@+id/txtLatestReport"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chưa có"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#2E7D32"/>
        </LinearLayout>

    </LinearLayout>

    <!-- LIST CARD -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardReportList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/layoutReportSummary"
        app:layout_constraintBottom_toBottomOf="parent">

        <ListView
            android:id="@+id/listViewReports"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="#EEEEEE"
            android:dividerHeight="1dp"
            android:padding="8dp"/>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>